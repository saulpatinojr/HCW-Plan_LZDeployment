# Copy this file to terraform.tfvars and fill in your values

management_subscription_id = "00000000-0000-0000-0000-000000000000"  # Replace with your Management subscription ID
org_prefix                 = "hcw"
primary_region             = "southcentralus"
primary_region_code        = "scus"

# SECURITY: Phase 1 Remediation (Finding 1.2 - CVSS 8.2)
# Public access now DISABLED by default. Enable only for initial bootstrap.
allow_public_access_during_setup = false  # Changed from true

# Private Endpoint Configuration (recommended for production)
enable_private_endpoint = true

# Required if enable_private_endpoint = true
# Deploy management VNet first, then provide these values
management_vnet_id   = "/subscriptions/<MGMT_SUB_ID>/resourceGroups/rg-network-mgmt-scus-prod-01/providers/Microsoft.Network/virtualNetworks/vnet-mgmt-scus-prod-01"
management_subnet_id = "/subscriptions/<MGMT_SUB_ID>/resourceGroups/rg-network-mgmt-scus-prod-01/providers/Microsoft.Network/virtualNetworks/vnet-mgmt-scus-prod-01/subnets/snet-private-endpoints"

# INITIAL BOOTSTRAP SEQUENCE (if starting from scratch):
# 1. First run with allow_public_access_during_setup = true, enable_private_endpoint = false
# 2. Deploy management VNet
# 3. Re-run with private endpoint enabled and public access disabled

default_tags = {
  owner       = "Platform Team"
  application = "Landing Zone Infrastructure"
  environment = "prod"
  cost_center = "IT-Platform"
  managed_by  = "Terraform"
}
